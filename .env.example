# ButtonDown API Key for newsletter publishing
BUTTONDOWN_API_KEY=your_api_key_here

# AT Protocol (Bluesky) credentials for publishing standard.site records
# Generate an app password at https://bsky.app/settings/app-passwords
ATPROTO_HANDLE=your-handle.bsky.social
ATPROTO_APP_PASSWORD=your_app_password_here
# Optional: defaults to https://bsky.social
ATPROTO_SERVICE=https://bsky.social